{
  "version": "1.1.0",
  "project": "Antigravity",
  "environment": "staging",
  "workspace": {
    "name": "BRAVEECOM_STITCH",
    "path": "./docs/antigravity",
    "autoSync": true,
    "syncInterval": 300
  },
  "qa_lead": {
    "name": "opencode",
    "email": "qa@antigravity.local",
    "role": "primary_tester",
    "ai_assistant": {
      "enabled": true,
      "provider": "gemini",
      "model": "gemini-2.0-pro",
      "temperature": 0.3,
      "maxTokens": 4096
    }
  },
  "validation": {
    "matchThreshold": 90,
    "minVerificationSources": 3,
    "requireOpencodeApproval": true,
    "seedDataEncryption": true,
    "productionSafetyLock": true
  },
  "auto_sync": {
    "enabled": true,
    "interval_seconds": 300,
    "sync_on_publish": true,
    "backup_to_cloud": false,
    "notify_on_failure": true,
    "recipients": ["qa@antigravity.local"]
  },
  "api_endpoints": {
    "staging": "http://localhost:3000/api/antigravity",
    "production": "https://braveecom.com/api/antigravity"
  },
  "features": {
    "nlp_semantic_scan": true,
    "deep_research_gate": true,
    "synthetic_data_sandbox": true,
    "gravity_well_validation": true,
    "manual_human_verification": true
  },
  "models": {
    "gemini": {
      "model": "gemini-2.0-pro",
      "display_name": "Gemini 2.0 Pro",
      "context_window": 2000000,
      "supports_vision": true,
      "supports_json": true
    },
    "gemini_pro_3_1": {
      "model": "gemini-2.0-pro",
      "display_name": "Gemini 2.0 Pro (Default)",
      "context_window": 2000000,
      "supports_vision": true,
      "supports_json": true,
      "is_default": true
    }
  },
  "debugger": {
    "enabled": true,
    "model": "gemini-2.0-pro",
    "logLevel": "verbose",
    "capture_all_requests": true,
    "performance_monitoring": true,
    "error_tracking": true
  }
}
